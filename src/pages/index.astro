---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import bookImg from '../assets/home/book.webp';
import friendsLogoImg from '../assets/home/friends_logo.png';

const allBlogPosts = await getCollection('blog', ({ data }) => data.published === true);
const latestPosts = allBlogPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const hackCategories = ['react', 'neovim', 'philosophy', 'microfrontend', 'software-philosophy'];

const projects = [
  {
    title: 'clipssh',
    description: 'Send clipboard screenshots to remote SSH hosts. Perfect for Claude Code over SSH.',
    tech: ['CLI', 'SSH', 'Clipboard'],
    link: 'https://github.com/samuellawrentz/clipssh',
  },
  {
    title: 'kron',
    description: 'krontab.xyz - Cron, but it actually tells you what happened. A smarter cron runner with logging and notifications.',
    tech: ['CLI', 'Cron', 'Rust'],
    link: 'https://krontab.xyz/',
  },
  {
    title: 'JIRA Commit Helper',
    description: 'A VSCode extension that supercharges your Git workflow by integrating JIRA ticket IDs into commit messages automatically.',
    tech: ['VSCode Extension', 'TypeScript', 'JIRA API'],
    link: 'https://marketplace.visualstudio.com/items?itemName=samuellawrentz.jira-commit-helper',
  },
  {
    title: 'Quotes Generator',
    description: 'A browser-based image quote generator that creates beautiful quote images with Unsplash backgrounds. No login required.',
    tech: ['React', 'Canvas API', 'Unsplash'],
    link: '/projects/quotes-generator/',
  },
  {
    title: 'React Highlight Textbox',
    description: 'A React component that highlights specific words or patterns inside a text input in real-time.',
    tech: ['React', 'CSS', 'npm'],
    link: 'https://www.npmjs.com/package/react-highlight-textbox',
  },
  {
    title: 'rc-json-editor',
    description: 'A lightweight, dependency-free JSON editor component for React with syntax highlighting and validation.',
    tech: ['React', 'TypeScript', 'npm'],
    link: 'https://www.npmjs.com/package/rc-json-editor',
  },
  {
    title: 'commit-helper',
    description: 'A CLI tool to streamline git commit message generation with JIRA integration and conventional commits support.',
    tech: ['Node.js', 'CLI', 'Git'],
    link: 'https://github.com/samuellawrentz/commit-helper',
  },
  {
    title: 'PastTenser',
    description: 'A fun API that returns the past tense of any English verb. Built with NodeJS and hosted as a public endpoint.',
    tech: ['Node.js', 'Express', 'REST API'],
    link: '/projects/pasttenser/',
  },
];

const featuredPost = allBlogPosts.find((p) => p.data.featured === true);
const featured = featuredPost ?? latestPosts[0];
const restPosts = latestPosts.filter((p) => p.id !== featured?.id).slice(0, 3);

const formatDate = (d: Date | string) =>
  new Date(d).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Samuel Lawrentz - Design × Code × Systems"
  description="Samuel Lawrentz - Engineer and team lead building pixel-perfect UIs and end-to-end systems. Writing about React, TypeScript, CSS, and the craft of software."
>
  <SEO
    slot="head"
    title="Samuel Lawrentz - Design × Code × Systems"
    description="Samuel Lawrentz - Engineer and team lead building pixel-perfect UIs and end-to-end systems. Writing about React, TypeScript, CSS, and the craft of software."
  />
  <div class="page-grain" aria-hidden="true"></div>
  <div class="dev-home">

    <!-- Hero -->
    <section class="hero">
      <div class="hero__layout">
        <div class="hero__text">
          <p class="hero__prompt reveal" style="--r:0">
            <span class="p-path">~/samuellawrentz</span> <span class="p-dollar">$</span> whoami
          </p>
          <h1 class="hero__heading reveal" style="--r:1">
            Samuel<br /><span class="hero__nowrap">Lawrentz<span class="hero__caret" aria-hidden="true"></span></span>
          </h1>
          <p class="hero__tagline reveal" style="--r:2"><span id="tagline"></span></p>
          <p class="hero__bio reveal" style="--r:3">
            <b>Engineer</b> who builds - pixel-perfect UIs, end-to-end systems, and design systems that scale.
            Turning complex problems into elegant, maintainable solutions.
          </p>
          <p class="hero__philosophy reveal" style="--r:4">
            <span class="t-comment">// "Simplicity is the ultimate sophistication in code."</span>
          </p>
        </div>

        <div class="hero__visual reveal" style="--r:2">
          <div class="term" role="img" aria-label="Terminal session introducing Samuel Lawrentz">
            <div class="term__bar">
              <span class="term__dot term__dot--r"></span>
              <span class="term__dot term__dot--y"></span>
              <span class="term__dot term__dot--g"></span>
              <span class="term__title">sam@web — zsh</span>
            </div>
            <div class="term__body">
              <p class="term__line" style="--i:0"><span class="t-dollar">$</span> whoami</p>
              <p class="term__line term__out" style="--i:1">engineer · team lead · frontend at heart</p>
              <p class="term__line" style="--i:2"><span class="t-dollar">$</span> ls ./expertise</p>
              <p class="term__line term__out" style="--i:3">
                <span class="t-dir">react/</span> <span class="t-dir">typescript/</span>
                <span class="t-dir">node/</span> <span class="t-dir">design-systems/</span>
              </p>
              <p class="term__line" style="--i:4"><span class="t-dollar">$</span> uptime</p>
              <p class="term__line term__out" style="--i:5">9+ years building for the web</p>
              <p class="term__line" style="--i:6"><span class="t-dollar">$</span> <span class="term__cursor"></span></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section class="ed-section" data-num="01">
      <div class="ed-section__header">
        <div>
          <p class="cmd"><span class="p-dollar">$</span> ls ./blog --sort=latest</p>
          <h2 class="ed-section__title">Blog</h2>
        </div>
        <a href="/blog/" class="section__link">cd /blog →</a>
      </div>

      <div class="blog-editorial">
        {featured && (
          <a href={featured.data.path} class="blog-featured">
            {featured.data.heroImage && (
              <div class="blog-featured__img">
                <Image src={featured.data.heroImage} alt={featured.data.title} width={720} height={400} />
              </div>
            )}
            <div class="blog-featured__body">
              <time class="blog-date">{formatDate(featured.data.date)}</time>
              <h3 class="blog-featured__title">{featured.data.title}</h3>
              {featured.data.description && <p class="blog-featured__desc">{featured.data.description}</p>}
              <div class="blog-tags">
                {featured.data.tags.map((tag: string) => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        )}

        <div class="blog-rest">
          {restPosts.map((post, i) => (
            <a href={post.data.path} class="blog-card">
              {post.data.heroImage && (
                <div class="blog-card__img">
                  <Image src={post.data.heroImage} alt={post.data.title} width={360} height={200} />
                </div>
              )}
              <div class="blog-card__body">
                <time class="blog-date"><span class="blog-card__index">0{i + 2}</span>{formatDate(post.data.date)}</time>
                <h4 class="blog-card__title">{post.data.title}</h4>
                <div class="blog-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="blog-cta">
        <div class="blog-cta__img">
          <Image src={bookImg} alt="Blog book" height={280} />
        </div>
        <div class="blog-cta__body">
          <h3>I write about Javascript, CSS, and all things web.</h3>
          <p>New content <b>every month</b> covering ReactJS, Typescript, NodeJS, CSS, and developer productivity.</p>
          <div class="blog-cta__links">
            <a href="/blog/" class="cta-link">All posts →</a>
            <a href="/rss.xml" class="cta-link">Subscribe via RSS →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="ed-section" data-num="02">
      <div class="ed-section__header">
        <div>
          <p class="cmd"><span class="p-dollar">$</span> cat projects.json</p>
          <h2 class="ed-section__title">Projects</h2>
        </div>
      </div>
      <div class="bento">
        {projects.map((project, i) => (
          <a
            href={project.link}
            target={project.link.startsWith('http') ? '_blank' : '_self'}
            rel="noreferrer"
            class:list={['bento__card', { 'bento__card--wide': i === 0 || i === 3 }]}
          >
            <span class="bento__index">[{i}]</span>
            <h3 class="bento__title">{project.title}</h3>
            <p class="bento__desc">{project.description}</p>
            <div class="blog-tags">
              {project.tech.map((t) => (
                <span class="blog-tag">{t}</span>
              ))}
            </div>
            <span class="bento__arrow" aria-hidden="true">{project.link.startsWith('http') ? '↗' : '→'}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Hacks -->
    <section class="ed-section" data-num="03">
      <div class="ed-section__header">
        <div>
          <p class="cmd"><span class="p-dollar">$</span> man hacks</p>
          <h2 class="ed-section__title">Hacks</h2>
        </div>
      </div>
      <p class="ed-section__subtitle">Short, practical tips and tricks across frontend topics. Pass a flag:</p>
      <div class="hacks-strip">
        {hackCategories.map((cat) => (
          <a href={`/hacks/${cat}/`} class="hack-pill">
            <span class="hack-pill__flag">--</span><span class="hack-pill__label">{cat}</span>
            <span class="hack-pill__arrow">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Social -->
    <section class="ed-section ed-social" data-num="04">
      <p class="cmd"><span class="p-dollar">$</span> ping samuel --all-channels</p>
      <div class="social__inner">
        <div class="social__info">
          <span class="social__logo-row">
            <span class="social__tagline">Let us be</span>
            <Image src={friendsLogoImg} alt="Friends" class="social__logo" width={180} height={45} />
          </span>
          <p class="social__name">Samuel Lawrentz</p>
          <p class="social__role">Software Development Manager — <a href="https://plivo.com" target="_blank" rel="noreferrer">Plivo</a></p>
        </div>
        <nav class="social__links">
          <a href="/about/">./about</a>
          <a href="https://github.com/samuellawrentz" target="_blank" rel="noreferrer">github ↗</a>
          <a href="https://in.linkedin.com/in/samuel-lawrentz" target="_blank" rel="noreferrer">linkedin ↗</a>
          <a href="https://twitter.com/samuellawrentz" target="_blank" rel="noreferrer">twitter ↗</a>
          <a href="https://codepen.io/samuellawrentz" target="_blank" rel="noreferrer">codepen ↗</a>
          <a href="https://www.google.com/search?q=samuel+lawrentz" target="_blank" rel="noreferrer">google me ↗</a>
        </nav>
      </div>
      <p class="eof"><span class="t-comment">// EOF — thanks for scrolling</span> <span class="eof__exit">✓ exit 0</span></p>
    </section>

  </div>
</BaseLayout>

<script>
  // Typing tagline
  const phrases = [
    'I craft pixel-perfect interfaces.',
    'I architect scalable frontends.',
    'I turn ideas into elegant code.',
  ];
  const el = document.getElementById('tagline');
  if (el) {
    let pi = 0;
    let ci = 0;
    let deleting = false;
    const speed = 60;
    const pause = 1800;

    function tick() {
      const phrase = phrases[pi];
      if (!deleting) {
        ci++;
        el.textContent = phrase.slice(0, ci);
        if (ci === phrase.length) {
          deleting = true;
          setTimeout(tick, pause);
          return;
        }
      } else {
        ci--;
        el.textContent = phrase.slice(0, ci);
        if (ci === 0) {
          deleting = false;
          pi = (pi + 1) % phrases.length;
        }
      }
      setTimeout(tick, deleting ? speed / 2 : speed);
    }
    tick();
  }
</script>

<style lang="scss">
  /* ───────── Scoped syntax palette ───────── */
  .dev-home {
    --syn-green: hsl(150, 55%, 28%);
    --syn-cyan: hsl(192, 75%, 26%);
    --syn-amber: hsl(32, 90%, 32%);
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  :global([color-mode='dark']) .dev-home {
    --syn-green: hsl(150, 50%, 58%);
    --syn-cyan: hsl(192, 65%, 60%);
    --syn-amber: hsl(38, 90%, 62%);
  }

  .p-dollar { color: var(--syn-green); }
  .p-path { color: var(--syn-cyan); }
  .t-comment { color: var(--element3); font-style: italic; }

  /* ───────── Grain overlay ───────── */
  .page-grain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px;
  }

  /* ───────── Load reveal ───────── */
  .reveal {
    opacity: 0;
    animation: rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--r, 0) * 0.12s);
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ───────── Hero ───────── */
  .hero {
    position: relative;
    padding: 72px 0 56px;
  }

  /* dot-grid atmosphere */
  .hero::before {
    content: '';
    position: absolute;
    inset: -20px -80px 0;
    background-image: radial-gradient(var(--element4) 1px, transparent 1.5px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 75% 85% at 72% 30%, black 0%, transparent 68%);
    mask-image: radial-gradient(ellipse 75% 85% at 72% 30%, black 0%, transparent 68%);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero__layout {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 56px;
    align-items: start;
  }

  .hero__text {
    max-width: 520px;
    min-width: 0;
  }

  .hero__nowrap {
    white-space: nowrap;
  }

  .hero__prompt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--element2);
    margin: 0 0 16px;
    letter-spacing: 0.02em;
  }

  .hero__heading {
    font-family: 'Sora', 'IBM Plex Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(48px, 7vw, 82px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin: 0 0 24px;
    text-shadow: none;
  }

  .hero__caret {
    display: inline-block;
    width: 0.14em;
    height: 0.82em;
    margin-left: 0.08em;
    background: var(--primary-color);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero__tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(15px, 2.5vw, 18px);
    color: var(--syn-amber);
    min-height: 1.6em;
    margin: 0 0 20px;
  }

  .hero__tagline span {
    border-right: 2px solid var(--primary-color);
    padding-right: 4px;
    animation: blink 0.8s step-end infinite;
  }

  .hero__bio {
    font-size: var(--body);
    line-height: 1.7;
    color: var(--element2);
    margin: 0 0 16px;
  }

  .hero__philosophy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    margin: 0;
  }

  /* ───────── Terminal window ───────── */
  .hero__visual {
    width: 350px;
    max-width: 100%;
    margin-top: 34px;
  }

  .term {
    background: hsl(222, 18%, 9%);
    border: 1px solid hsl(222, 10%, 24%);
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 24px 48px -16px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.03) inset,
      0 0 60px -20px hsla(349, 98%, 34%, 0.25);
    animation: termFloat 7s ease-in-out infinite;
  }

  @keyframes termFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .term__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    background: hsl(222, 14%, 14%);
    border-bottom: 1px solid hsl(222, 10%, 22%);
  }

  .term__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .term__dot--r { background: hsl(2, 80%, 62%); }
  .term__dot--y { background: hsl(42, 92%, 60%); }
  .term__dot--g { background: hsl(140, 60%, 52%); }

  .term__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: hsl(222, 8%, 55%);
    margin-left: auto;
    letter-spacing: 0.04em;
  }

  .term__body {
    padding: 18px 18px 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.75;
  }

  .term__line {
    margin: 0;
    color: hsl(220, 14%, 88%);
    opacity: 0;
    animation: termIn 0.35s ease forwards;
    animation-delay: calc(var(--i) * 0.4s + 0.6s);
    white-space: nowrap;
  }

  .term__out {
    color: hsl(222, 8%, 62%);
  }

  .term__line .t-dollar {
    color: hsl(150, 55%, 55%);
  }

  .t-dir {
    color: hsl(192, 70%, 62%);
  }

  @keyframes termIn {
    from { opacity: 0; transform: translateX(-6px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .term__cursor {
    display: inline-block;
    width: 8px;
    height: 15px;
    vertical-align: -2px;
    background: hsl(150, 55%, 55%);
    animation: blink 0.9s step-end infinite;
  }

  /* ───────── Section shared ───────── */
  .ed-section {
    padding: 56px 0;
    border-top: 1px solid var(--element4);
    margin: 0;
    position: relative;
  }

  /* section number sitting on the divider */
  .ed-section::before {
    content: attr(data-num);
    position: absolute;
    top: -0.7em;
    right: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--element3);
    background: var(--surface1);
    padding: 0 10px;
  }

  .ed-section__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    gap: 16px;
  }

  .cmd {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--element3);
    letter-spacing: 0.02em;
    margin: 0 0 4px;
  }

  .ed-section__title {
    font-family: 'Sora', 'IBM Plex Sans', sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .section__link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--element2);
    text-decoration: none;
    border-bottom: 1px solid var(--element4);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }

  .section__link:hover {
    color: var(--element1);
    border-bottom-color: var(--element1);
  }

  .ed-section__subtitle {
    color: var(--element2);
    margin: -16px 0 28px;
    font-size: var(--body);
  }

  /* ───────── Blog editorial grid ───────── */
  .blog-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .blog-featured {
    grid-row: 1 / 2;
    grid-column: 1 / 2;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    overflow: hidden;
    min-width: 0;
    border: 1px solid var(--element4);
    background: var(--surface2);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease, border-color 0.2s;
  }

  .blog-featured:hover {
    transform: translateY(-4px);
    border-color: var(--element3);
    box-shadow: 0 12px 32px -8px var(--card-shadow-color);
  }

  .blog-featured__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blog-featured__img :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .blog-featured:hover .blog-featured__img :global(img) {
    transform: scale(1.04);
  }

  .blog-featured__body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .blog-featured__title {
    font-family: 'Sora', 'IBM Plex Sans', sans-serif;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .blog-featured__desc {
    font-size: var(--caption);
    color: var(--element2);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-rest {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .blog-card {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    padding: 12px;
    border-radius: 10px;
    border: 1px solid transparent;
    min-width: 0;
    transition: border-color 0.2s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }

  .blog-card:hover {
    border-color: var(--element4);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px -6px var(--card-shadow-color);
  }

  .blog-card__img {
    border-radius: 6px;
