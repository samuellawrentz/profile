---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import IdeWindow from '../../../components/IdeWindow.astro';
import { formatDate, readTimeFromBody, slugifyTag, hashOf } from '../../../utils/blog';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => data.published === true);

  const tagSet = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag);
    }
  }

  return Array.from(tagSet).map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

const tabs = [
  { label: 'README.md', href: '/' },
  { label: 'blog.log', href: '/blog/' },
  { label: `grep:${slugifyTag(tag)}`, href: `/blog/tag/${slugifyTag(tag)}/`, active: true },
];
---

<BaseLayout title={`Posts tagged "${tag}" - Samuel Lawrentz`} description={`All blog posts tagged with "${tag}" on Samuel Lawrentz's blog.`}>
  <SEO slot="head" title={`Posts tagged "${tag}" - Samuel Lawrentz`} description={`All blog posts tagged with "${tag}" on Samuel Lawrentz's blog.`} />

  <IdeWindow tabs={tabs}>
    <Fragment slot="status-right">
      <span class="ide__status-item">{posts.length} {posts.length === 1 ? 'match' : 'matches'}</span>
      <span class="ide__status-item">UTF-8</span>
      <span class="ide__status-item t-red">♥ 2026</span>
    </Fragment>

    <section class="sec sec--grep">
      <header class="sec__head reveal" style="--r:0">
        <div>
          <p class="cmd"><span class="t-green">$</span> git log --oneline --grep="{tag}" ./blog</p>
          <h1 class="sec__title">Posts tagged <span class="grep-hl">"{tag}"</span></h1>
        </div>
        <a href="/blog/" class="sec__link">cd ../blog →</a>
      </header>

      {posts.length === 0 && (
        <p class="grep-empty">grep: no matches found</p>
      )}

      <ol class="gitlog reveal" style="--r:1">
        {posts.map((post) => (
          <li class="commit">
            <span class="commit__graph" aria-hidden="true"><i class="commit__node"></i></span>
            <a href={post.data.path} class="commit__card">
              <div class="commit__main">
                <p class="commit__line1">
                  <code class="commit__hash">{hashOf(post.data.title)}</code>
                  <span class="commit__title">{post.data.title}</span>
                </p>
                <p class="commit__meta">
                  <span>{formatDate(post.data.date)}</span>
                  <span>{readTimeFromBody(post.body)}</span>
                  {post.data.tags.slice(0, 3).map((t) => (
                    <span class:list={['commit__tag', { 'commit__tag--hl': t === tag }]}>tag: {t}</span>
                  ))}
                </p>
                {post.data.description && (
                  <p class="commit__desc">{post.data.description}</p>
                )}
              </div>
              {post.data.heroImage && (
                <div class="commit__thumb">
                  <Image src={post.data.heroImage} alt={post.data.title} width={280} height={168} />
                </div>
              )}
            </a>
          </li>
        ))}
      </ol>
    </section>
  </IdeWindow>
</BaseLayout>

<style lang="scss">
  .sec--grep {
    padding-top: 48px;
  }

  .grep-hl {
    color: var(--syn-amber);
  }

  .grep-empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--syn-red);
    padding: 32px 0;
  }

  .commit__tag--hl {
    color: var(--syn-amber);
    font-weight: 700;
  }
</style>
