---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import IdeWindow from '../../../components/IdeWindow.astro';
import { formatDate, readTimeFromBody, slugifyTag, hashOf } from '../../../utils/blog';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => data.published === true);

  const tagSet = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag);
    }
  }

  return Array.from(tagSet).map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

const tabs = [
  { label: 'README.md', href: '/' },
  { label: 'blog.log', href: '/blog/' },
  { label: `grep:${slugifyTag(tag)}`, href: `/blog/tag/${slugifyTag(tag)}/`, active: true },
];
---

<BaseLayout title={`Posts tagged "${tag}" - Samuel Lawrentz`} description={`All blog posts tagged with "${tag}" on Samuel Lawrentz's blog.`}>
  <SEO slot="head" title={`Posts tagged "${tag}" - Samuel Lawrentz`} description={`All blog posts tagged with "${tag}" on Samuel Lawrentz's blog.`} />

  <IdeWindow tabs={tabs}>
    <Fragment slot="status-right">
      <span class="ide__status-item">{posts.length} {posts.length === 1 ? 'match' : 'matches'}</span>
      <span class="ide__status-item">UTF-8</span>
      <span class="ide__status-item t-red">♥ 2026</span>
    </Fragment>

    <section class="sec sec--grep">
      <header class="sec__head reveal" style="--r:0">
        <div>
          <p class="cmd"><span class="t-green">$</span> git log --oneline --grep="{tag}" ./blog</p>
          <h1 class="sec__title">Posts tagged <span class="grep-hl">"{tag}"</span></h1>
        </div>
        <a href="/blog/" class="sec__link">cd ../blog →</a>
      </header>

      {posts.length === 0 && (
        <p class="grep-empty">grep: no matches found</p>
      )}

      <ol class="oneline reveal" style="--r:1">
        {posts.map((post) => (
          <li>
            <a href={post.data.path} class="oneline__row" title={post.data.description}>
              <code class="oneline__hash">{hashOf(post.data.title)}</code>
              <span class="oneline__title">{post.data.title}</span>
              <span class="oneline__meta">
                <span>{formatDate(post.data.date)}</span>
                <span>{readTimeFromBody(post.body)}</span>
                <span class="commit__tag commit__tag--hl">tag: {tag}</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </IdeWindow>
</BaseLayout>

<style lang="scss">
  .sec--grep {
    padding-top: 48px;
  }

  .grep-hl {
    color: var(--syn-amber);
  }

  .grep-empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--syn-red);
    padding: 32px 0;
  }

  .commit__tag--hl {
    color: var(--syn-amber);
    font-weight: 700;
  }
</style>
