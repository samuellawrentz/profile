---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import IdeWindow from '../../components/IdeWindow.astro';
import { Image } from 'astro:assets';
import GiscusComments from '../../components/GiscusComments';
import { formatDate, readTimeFromBody, wordCount, slugifyTag, hashOf } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.published === true);
  return posts.map(post => {
    const slug = post.data.path.replace(/^\/blog\//, '').replace(/\/$/, '');
    return { params: { slug }, props: { post } };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => data.published === true);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.published === true)
  .sort((a, b) => {
    const sharedA = a.data.tags.filter((t: string) => post.data.tags.includes(t)).length;
    const sharedB = b.data.tags.filter((t: string) => post.data.tags.includes(t)).length;
    if (sharedB !== sharedA) return sharedB - sharedA;
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  })
  .slice(0, 4);

const ogImagePath = `/og-images/${post.data.path.replace(/[/-]/gi, '')}.png`;

const dateStr = formatDate(post.data.date);
const readTime = readTimeFromBody(post.body);
const words = wordCount(post.body);
const hash = hashOf(post.data.title);

const slug = post.data.path.replace(/^\/blog\//, '').replace(/\/$/, '');
const fileName = slug.length > 26 ? `${slug.slice(0, 24)}…` : slug;

const tabs = [
  { label: 'README.md', href: '/' },
  { label: 'blog.log', href: '/blog/' },
  { label: `${fileName}.md`, href: post.data.path, active: true, title: `${slug}.md` },
];
---
<BaseLayout title={`Samuel Lawrentz | ${post.data.title}`} description={post.data.description}>
  <SEO slot="head" title={`Samuel Lawrentz | ${post.data.title}`} description={post.data.description} image={ogImagePath} article={true} publishedDate={post.data.date instanceof Date ? post.data.date.toISOString() : String(post.data.date)} type="article" />

  <IdeWindow tabs={tabs}>
    <Fragment slot="status-right">
      <span class="ide__status-item">markdown</span>
      <span class="ide__status-item">{words} words</span>
      <span class="ide__status-item">{readTime}</span>
      <span class="ide__status-item t-green" id="read-progress">0%</span>
    </Fragment>

    <div class="post-vars">

      {/* ── Article ── */}
      <article class="sec post">
        <p class="post__crumb reveal" style="--r:0">
          <a href="/blog/" class="post__back">← blog</a>
          <span class="post__crumb-path"><span class="y-key">blog</span> / <b>{slug}.md</b></span>
        </p>

        <p class="post__meta reveal" style="--r:1">
          <code class="commit__hash">{hash}</code>
          <span>{dateStr}</span>
          <span>{readTime}</span>
        </p>

        <h1 class="post__title reveal" style="--r:2">{post.data.title}</h1>

        {post.data.description && (
          <p class="post__desc reveal" style="--r:3">{post.data.description}</p>
        )}

        {post.data.tags && post.data.tags.length > 0 && (
          <p class="post__tags reveal" style="--r:4">
            <span class="j-punc">(</span>
            {post.data.tags.map((tag: string, i: number) => (
              <><a href={'/blog/tag/' + slugifyTag(tag) + '/'} class="post__tag">tag: {tag}</a>{i < post.data.tags.length - 1 && <span class="j-punc">, </span>}</>
            ))}
            <span class="j-punc">)</span>
          </p>
        )}

        {post.data.heroImage && (
          <div class="post__hero reveal" style="--r:5">
            <Image
              src={post.data.heroImage}
              alt={post.data.title}
              width={900}
              height={480}
              class="post__hero-img"
            />
          </div>
        )}

        <div class="article-content">
          <Content />
        </div>
      </article>

      {/* ── Signature ── */}
      <section class="sec sig" data-file="signature.txt">
        <div class="sig__card">
          <div class="sig__text">
            <p class="sig__thanks">Thanks for reading!</p>
            <p class="sig__bio">
              I write about frontend craft, React, TypeScript, and the web. Found this useful? Let me know.
            </p>
          </div>
          <a
            href="https://x.com/samuellawrentz"
            target="_blank"
            rel="noreferrer"
            class="sig__cta"
          >
            @samuellawrentz →
          </a>
        </div>
        <p class="sec__foot">
          <span class="t-green">$</span> echo "enjoyed this post?" · <a href="/rss.xml">subscribe via rss ↗</a>
        </p>
      </section>

      {/* ── Related ── */}
      {relatedPosts.length > 0 && (
        <section class="sec" data-file="related.log">
          <header class="sec__head">
            <div>
              <p class="cmd"><span class="t-green">$</span> git log --oneline --grep="{post.data.tags[0] ?? 'web'}"</p>
              <h2 class="sec__title">More articles</h2>
            </div>
            <a href="/blog/" class="sec__link">cd ../blog →</a>
          </header>
          <ol class="gitlog">
            {relatedPosts.map((p) => (
              <li class="commit">
                <span class="commit__graph" aria-hidden="true"><i class="commit__node"></i></span>
                <a href={p.data.path} class="commit__card">
                  <div class="commit__main">
                    <p class="commit__line1">
                      <code class="commit__hash">{hashOf(p.data.title)}</code>
                      <span class="commit__title">{p.data.title}</span>
                    </p>
                    <p class="commit__meta">
                      <span>{formatDate(p.data.date)}</span>
                      <span>{readTimeFromBody(p.body)}</span>
                      {p.data.tags.slice(0, 2).map((tag: string) => (
                        <span class="commit__tag">tag: {tag}</span>
                      ))}
                    </p>
                  </div>
                  {p.data.heroImage && (
                    <div class="commit__thumb">
                      <Image src={p.data.heroImage} alt={p.data.title} width={280} height={168} />
                    </div>
                  )}
                </a>
              </li>
            ))}
          </ol>
        </section>
      )}

      {/* ── Comments ── */}
      <section class="sec" data-file="comments/">
        <p class="cmd comments-cmd"><span class="t-green">$</span> giscus --load ./comments</p>
        <GiscusComments client:visible />
      </section>

    </div>
  </IdeWindow>
</BaseLayout>

<script>
  // Reading progress in the status bar
  const progress = document.getElementById('read-progress');
  if (progress) {
    const onScroll = () => {
      const h = document.documentElement;
      const total = h.scrollHeight - h.clientHeight;
      const pct = total > 0 ? Math.min(100, Math.round((h.scrollTop / total) * 100)) : 100;
      progress.textContent = `${pct}%`;
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>

<style lang="scss">
  /* Map site tokens to editor tokens so shared prose styles work inside the window */
  .post-vars {
    --element1: var(--ide-text);
    --element2: color-mix(in srgb, var(--ide-text) 82%, var(--ide-dim));
    --element3: var(--ide-dim);
    --element4: var(--ide-border);
    --surface2: var(--ide-faint);
    --primary-color: var(--syn-red);
  }

  /* ── Post header ── */
  .post {
    padding-top: 40px;
  }

  .post__crumb {
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--ide-dim);
    margin: 0 0 32px;

    b { color: var(--ide-text); font-weight: 500; }
  }

  .post__back {
    color: var(--ide-dim);
    text-decoration: none;
    border-bottom: 1px solid var(--ide-border);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;

    &:hover {
      color: var(--ide-text);
      border-bottom-color: var(--ide-text);
    }
  }

  .post__meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ide-dim);
    margin: 0 0 16px;
  }

  .post__title {
    font-family: 'Sora', 'IBM Plex Sans', sans-serif;
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--ide-text);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    max-width: 820px;
    text-shadow: none;

    &::before {
      content: '# ';
      color: var(--syn-red);
      font-weight: 700;
    }
  }

  .post__desc {
    font-size: 1.05rem;
    color: var(--ide-dim);
    line-height: 1.65;
    max-width: 720px;
    margin: 0 0 1.25rem;
  }

  .post__tags {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    margin: 0 0 2.5rem;
  }

  .post__tag {
    color: var(--syn-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;

    &:hover { border-bottom-color: var(--syn-cyan); }
  }

  /* ── Hero image ── */
  .post__hero {
    margin-bottom: 3rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--ide-border);
  }

  .post__hero-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* ── Article body (prose) ── */
  .article-content {
    border-top: 1px dashed var(--ide-border);
    padding-top: 2.5rem;
    max-width: 720px;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--element2);
  }

  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    color: var(--element1);
    letter-spacing: -0.02em;
    margin-top: 2.25em;
    margin-bottom: 0.75em;
    text-shadow: none;
  }

  .article-content :global(h2) {
    font-size: 1.6rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--element4);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.5em;
  }

  .article-content :global(a) {
    font-family: inherit;
    color: var(--primary-color);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--primary-color) 40%, transparent);
    transition: border-color 0.2s;
  }

  .article-content :global(a:hover) {
    border-bottom-color: var(--primary-color);
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--primary-color);
    margin: 2em 0;
    padding: 0.75em 1.5em;
    background: var(--surface2);
    border-radius: 0 8px 8px 0;
    color: var(--element2);
    font-style: italic;
  }

  .article-content :global(pre) {
    border-radius: 8px;
    border: 1px solid var(--element4);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    overflow-x: auto;
    margin: 1.75em 0;
    padding: 1.25em 1.5em;
  }

  .article-content :global(pre code) {
    font-family: inherit;
    font-size: inherit;
    background: none !important;
    border: none !important;
    padding: 0 !important;
    border-radius: 0;
    color: inherit;
  }

  .article-content :global(code:not(pre code)) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: var(--surface2);
    border: 1px solid var(--element4);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--element1);
  }

  .article-content :global(strong) {
    color: var(--element1);
    font-weight: 700;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }

  .article-content :global(li) {
    margin-bottom: 0.4em;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px dashed var(--element4);
    margin: 2.5em 0;
  }

  .article-content :global(img) {
    border-radius: 8px;
    border: 1px solid var(--element4);
    max-width: 100%;
    height: auto;
    margin: 1.5em 0;
  }

  /* ── Signature ── */
  .sig__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 28px 32px;
    border-radius: 12px;
    background: var(--ide-faint);
    border: 1px solid var(--ide-border);
    flex-wrap: wrap;
  }

  .sig__thanks {
    font-family: 'Sora', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ide-text);
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }

  .sig__bio {
    font-size: 0.9rem;
    color: var(--ide-dim);
    margin: 0;
    line-height: 1.55;
    max-width: 440px;
  }

  .sig__cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--ide-text);
    text-decoration: none;
    border: 1px solid var(--ide-border);
    padding: 0.6em 1.1em;
    border-radius: 6px;
    background: transparent;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    flex-shrink: 0;

    &:hover {
      background: var(--ide-text);
      color: var(--ide-bg);
      border-color: var(--ide-text);
    }
  }

  /* ── Comments ── */
  .comments-cmd {
    margin-bottom: 24px;
  }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .post {
      padding-top: 28px;
    }

    .post__crumb {
      gap: 12px;
    }

    .sig__card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>
