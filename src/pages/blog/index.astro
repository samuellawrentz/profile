---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import IdeWindow from '../../components/IdeWindow.astro';
import { formatDate, readTimeFromBody, hashOf } from '../../utils/blog';

const posts = (await getCollection('blog', ({ data }) => data.published === true))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const byYear = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = new Date(post.data.date).getFullYear();
  (acc[year] ??= []).push(post);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const tabs = [
  { label: 'README.md', href: '/' },
  { label: 'blog.log', href: '/blog/', active: true },
  { label: 'projects.json', href: '/#projects' },
  { label: 'hacks/', href: '/hacks/' },
  { label: 'socials.yml', href: '/#socials' },
];
---
<BaseLayout title="Blog - Samuel Lawrentz">
  <SEO slot="head" title="Blog - Samuel Lawrentz" description="Tech blog about frontend development, React, TypeScript, and web technologies" />

  <IdeWindow tabs={tabs}>
    <Fragment slot="status-right">
      <span class="ide__status-item">{posts.length} commits</span>
      <span class="ide__status-item">UTF-8</span>
      <span class="ide__status-item">astro 5</span>
      <span class="ide__status-item t-red">♥ 2026</span>
    </Fragment>

    <section class="sec sec--log">
      <header class="sec__head reveal" style="--r:0">
        <div>
          <p class="cmd"><span class="t-green">$</span> git log --graph --all ./blog</p>
          <h1 class="sec__title">Blog</h1>
        </div>
        <span class="log-count">{posts.length} commits</span>
      </header>
      <p class="sec__sub reveal" style="--r:1">
        Writing about frontend craft, developer tooling, and the things I learn along the way.
      </p>

      {posts.length === 0 && (
        <p class="log-empty">fatal: your current branch 'main' does not have any commits yet</p>
      )}

      <ol class="gitlog reveal" style="--r:2">
        {years.map((year, yi) => (
          <>
            <li class="commit commit--year">
              <span class="commit__graph" aria-hidden="true"><i class="year-node"></i></span>
              <p class="year-label">
                <span class="t-amber">(tag: v{year})</span>
                <span class="year-count">{byYear[year].length} {byYear[year].length === 1 ? 'commit' : 'commits'}</span>
              </p>
            </li>
            {byYear[year].map((post, i) => (
              <li class:list={['commit', { 'commit--head': yi === 0 && i === 0 }]}>
                <span class="commit__graph" aria-hidden="true"><i class="commit__node"></i></span>
                <a href={post.data.path} class="commit__card">
                  <div class="commit__main">
                    <p class="commit__line1">
                      <code class="commit__hash">{hashOf(post.data.title)}</code>
                      {yi === 0 && i === 0 && <span class="commit__ref">(HEAD → latest)</span>}
                      <span class="commit__title">{post.data.title}</span>
                    </p>
                    <p class="commit__meta">
                      <span>{formatDate(post.data.date)}</span>
                      <span>{readTimeFromBody(post.body)}</span>
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="commit__tag">tag: {tag}</span>
                      ))}
                    </p>
                    {post.data.description && (
                      <p class="commit__desc">{post.data.description}</p>
                    )}
                  </div>
                  {post.data.heroImage && (
                    <div class="commit__thumb">
                      <Image src={post.data.heroImage} alt={post.data.title} width={280} height={168} />
                    </div>
                  )}
                </a>
              </li>
            ))}
          </>
        ))}
      </ol>

      <p class="sec__foot">
        <span class="t-green">$</span> echo "new post every month" · <a href="/rss.xml">subscribe via rss ↗</a>
      </p>
    </section>
  </IdeWindow>
</BaseLayout>

<style lang="scss">
  .sec--log {
    padding-top: 48px;
  }

  .log-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ide-dim);
    border: 1px solid var(--ide-border);
    border-radius: 100px;
    padding: 5px 12px;
    white-space: nowrap;
  }

  .log-empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--syn-red);
    padding: 32px 0;
  }

  /* year marker rows inside the graph rail */
  .commit--year:not(:first-child) {
    margin-top: 28px;
  }

  .year-node {
    position: absolute;
    top: 14px;
    left: -1px;
    width: 14px;
    height: 14px;
    transform: rotate(45deg);
    background: var(--ide-bg);
    border: 2.5px solid var(--syn-amber);
    border-radius: 3px;
  }

  .year-label {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin: 0;
    padding: 8px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
  }

  .year-count {
    font-size: 11.5px;
    font-weight: 400;
    color: var(--ide-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
