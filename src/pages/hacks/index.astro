---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import IdeWindow from '../../components/IdeWindow.astro';

const hacks = await getCollection('hacks');
const categories = [...new Set(hacks.map(h => {
  const parts = h.data.path.split('/');
  return parts[2];
}))];

const categoryDescriptions: Record<string, string> = {
  react: 'Hooks, patterns, state management, and performance tips for React.',
  neovim: 'Configuration, plugins, LSP setup, and workflow optimization.',
  microfrontend: 'Architecture, integration, deployment, and scaling strategies.',
  philosophy: 'Principles, ethics, and philosophical perspectives on craft.',
  'software-philosophy': 'Agile thinking, open source, and development methodologies.',
};

const categoryData = categories.map(cat => ({
  name: cat,
  items: hacks.filter(h => h.data.path.includes(`/hacks/${cat}/`)),
  description: categoryDescriptions[cat] || 'Quick tips and short-form content.',
})).sort((a, b) => b.items.length - a.items.length);

const totalHacks = hacks.length;

const ensureTrailingSlash = (p: string) => p.endsWith('/') ? p : p + '/';

const tabs = [
  { label: 'README.md', href: '/' },
  { label: 'blog.log', href: '/blog/' },
  { label: 'hacks/', href: '/hacks/', active: true },
  { label: 'socials.yml', href: '/#socials' },
];
---
<BaseLayout title="Hacks - Samuel Lawrentz">
  <SEO slot="head" title="Hacks - Samuel Lawrentz" description="Quick tips, tricks, and short-form content on React, Neovim, microfrontends, and software philosophy." />

  <IdeWindow tabs={tabs}>
    <Fragment slot="status-right">
      <span class="ide__status-item">{categoryData.length} directories</span>
      <span class="ide__status-item">{totalHacks} files</span>
      <span class="ide__status-item t-red">♥ 2026</span>
    </Fragment>

    <section class="sec sec--tree">
      <header class="sec__head reveal" style="--r:0">
        <div>
          <p class="cmd"><span class="t-green">$</span> tree ./hacks</p>
          <h1 class="sec__title">Hacks</h1>
        </div>
        <span class="tree-count">{totalHacks} entries</span>
      </header>
      <p class="sec__sub reveal" style="--r:1">
        Quick tips, tricks, and short-form notes - organized by topic.
      </p>

      <div class="tree reveal" style="--r:2">
        <p class="tree__root">hacks/</p>
        {categoryData.map((cat, ci) => {
          const lastDir = ci === categoryData.length - 1;
          return (
            <div class="tree__group">
              <a href={`/hacks/${cat.name}/`} class="tree__dir">
                <span class="tree__glyph" aria-hidden="true">{lastDir ? '└──' : '├──'}</span>
                <span class="tree__dirname">{cat.name}/</span>
                <span class="tree__count">{cat.items.length} {cat.items.length === 1 ? 'item' : 'items'}</span>
                <span class="tree__desc">{cat.description}</span>
              </a>
              {cat.items.map((h, hi) => (
                <a href={ensureTrailingSlash(h.data.path)} class="tree__file">
                  <span class="tree__glyph" aria-hidden="true">{lastDir ? '   ' : '│  '} {hi === cat.items.length - 1 ? '└──' : '├──'}</span>
                  <span class="tree__filename">{h.data.title}</span>
                  <span class="tree__arrow" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          );
        })}
      </div>

      <p class="sec__foot">{categoryData.length} directories, {totalHacks} files</p>
    </section>
  </IdeWindow>
</BaseLayout>

<style lang="scss">
  .sec--tree {
    padding-top: 48px;
  }

  .tree-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ide-dim);
    border: 1px solid var(--ide-border);
    border-radius: 100px;
    padding: 5px 12px;
    white-space: nowrap;
  }

  .tree {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13.5px;
    line-height: 1.5;
  }

  .tree__root {
    margin: 0 0 2px;
    font-weight: 700;
    color: var(--syn-cyan);
  }

  .tree__glyph {
    color: var(--ide-border);
    white-space: pre;
    flex-shrink: 0;
  }

  .tree__dir,
  .tree__file {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 6px 10px 6px 0;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    min-width: 0;
    transition: background 0.15s;

    &:hover {
      background: var(--ide-faint);
    }
  }

  .tree__dir {
    margin-top: 10px;
  }

  .tree__dirname {
    font-weight: 700;
    color: var(--syn-cyan);
    white-space: nowrap;
  }

  .tree__count {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--syn-amber);
    white-space: nowrap;
  }

  .tree__desc {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    color: var(--ide-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tree__filename {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14.5px;
    color: var(--ide-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tree__file:hover .tree__filename {
    color: var(--syn-cyan);
  }

  .tree__arrow {
    margin-left: auto;
    padding-right: 8px;
    color: var(--ide-dim);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s, transform 0.25s;
    flex-shrink: 0;
  }

  .tree__file:hover .tree__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 680px) {
    .tree__desc {
      display: none;
    }

    .tree {
      font-size: 12.5px;
    }

    .tree__filename {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  }
</style>
