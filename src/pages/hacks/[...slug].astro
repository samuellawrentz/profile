---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import IdeWindow from '../../components/IdeWindow.astro';
import { formatDate, readTimeFromBody, wordCount, hashOf } from '../../utils/blog';

export async function getStaticPaths() {
  const hacks = await getCollection('hacks');
  const paths = [];

  // Individual hack pages
  for (const hack of hacks) {
    const slug = hack.data.path.replace(/^\/hacks\//, '').replace(/\/$/, '');
    paths.push({ params: { slug }, props: { hack, isCategory: false } });
  }

  // Category listing pages
  const categories = [...new Set(hacks.map(h => {
    const parts = h.data.path.split('/');
    return parts[2];
  }))];

  for (const cat of categories) {
    const catHacks = hacks.filter(h => h.data.path.includes(`/hacks/${cat}/`));
    paths.push({ params: { slug: cat }, props: { hack: null, isCategory: true, categoryName: cat, categoryHacks: catHacks } });
  }

  return paths;
}

const { hack, isCategory, categoryName, categoryHacks } = Astro.props;

let Content;
let relatedHacks;
let hackCategory = '';

if (!isCategory && hack) {
  const rendered = await render(hack);
  Content = rendered.Content;
  hackCategory = hack.data.path.split('/')[2];
  const allHacks = await getCollection('hacks');
  relatedHacks = allHacks
    .filter(h => h.id !== hack.id && h.data.path.includes(`/hacks/${hackCategory}/`))
    .slice(0, 4);
  if (relatedHacks.length < 4) {
    const more = allHacks.filter(h => h.id !== hack.id && !relatedHacks.includes(h)).slice(0, 4 - relatedHacks.length);
    relatedHacks = [...relatedHacks, ...more];
  }
}

const categoryDisplay = (cat: string) => cat.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
const ensureTrailingSlash = (p: string) => p.endsWith('/') ? p : p + '/';

const hackSlug = hack ? hack.data.path.replace(/^\/hacks\/[^/]+\//, '').replace(/\/$/, '') : '';
const hackFile = hackSlug.length > 26 ? `${hackSlug.slice(0, 24)}…` : hackSlug;

const tabs = isCategory
  ? [
      { label: 'README.md', href: '/' },
      { label: 'hacks/', href: '/hacks/' },
      { label: `${categoryName}/`, href: `/hacks/${categoryName}/`, active: true },
    ]
  : [
      { label: 'README.md', href: '/' },
      { label: 'hacks/', href: '/hacks/' },
      { label: `${hackCategory}/`, href: `/hacks/${hackCategory}/` },
      { label: `${hackFile}.md`, href: ensureTrailingSlash(hack!.data.path), active: true, title: `${hackSlug}.md` },
    ];

const words = hack ? wordCount(hack.body) : 0;
const readTime = hack ? readTimeFromBody(hack.body) : '';
---
<BaseLayout title={isCategory ? `${categoryDisplay(categoryName!)} - Hacks` : hack?.data.title} description={hack?.data.description}>
  {!isCategory && hack && (
    <SEO slot="head" title={hack.data.title} description={hack.data.description} image={`/og-images/${hack.data.path.replace(/[/-]/gi, '')}.png`} article={true} />
  )}

  {isCategory ? (
    <IdeWindow tabs={tabs}>
      <Fragment slot="status-right">
        <span class="ide__status-item">{categoryHacks?.length} files</span>
        <span class="ide__status-item">UTF-8</span>
        <span class="ide__status-item t-red">♥ 2026</span>
      </Fragment>

      <section class="sec sec--cat">
        <header class="sec__head reveal" style="--r:0">
          <div>
            <p class="cmd"><span class="t-green">$</span> ls -la ./hacks/{categoryName}</p>
            <h1 class="sec__title">{categoryDisplay(categoryName!)}</h1>
          </div>
          <a href="/hacks/" class="sec__link">cd ../hacks →</a>
        </header>

        <div class="ls reveal" style="--r:1">
          <p class="ls__total">total {categoryHacks?.length}</p>
          {categoryHacks?.map((h) => (
            <a href={ensureTrailingSlash(h.data.path)} class="ls__row ls__row--file">
              <span class="ls__perm">-rw-r--r--</span>
              <span class="ls__owner">sam</span>
              <span class="ls__file-body">
                <span class="ls__name">{h.data.title}</span>
                {h.data.description && <span class="ls__desc">{h.data.description}</span>}
              </span>
              <span class="ls__arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>
    </IdeWindow>
  ) : (
    <IdeWindow tabs={tabs}>
      <Fragment slot="status-right">
        <span class="ide__status-item">markdown</span>
        <span class="ide__status-item">{words} words</span>
        <span class="ide__status-item">{readTime}</span>
        <span class="ide__status-item t-green" id="read-progress">0%</span>
      </Fragment>

      <div class="post-vars">

        <article class="sec post">
          <p class="post__crumb reveal" style="--r:0">
            <a href={`/hacks/${hackCategory}/`} class="post__back">← {hackCategory}</a>
            <span><span class="y-key">hacks</span> / <span class="y-key">{hackCategory}</span> / <b>{hackSlug}.md</b></span>
          </p>

          <p class="post__meta reveal" style="--r:1">
            <code class="commit__hash">{hashOf(hack!.data.title)}</code>
            {hack!.data.date && <span>{formatDate(hack!.data.date)}</span>}
            <span>{readTime}</span>
          </p>

          <h1 class="post__title reveal" style="--r:2">{hack!.data.title}</h1>

          {hack!.data.description && (
            <p class="post__desc reveal" style="--r:3">{hack!.data.description}</p>
          )}

          {hack!.data.tags && hack!.data.tags.length > 0 && (
            <p class="post__tags reveal" style="--r:4">
              <span class="j-punc">(</span>
              {hack!.data.tags.map((tag: string, i: number) => (
                <><span class="post__tag">tag: {tag}</span>{i < hack!.data.tags.length - 1 && <span class="j-punc">, </span>}</>
              ))}
              <span class="j-punc">)</span>
            </p>
          )}

          <div class="article-content">
            {Content && <Content />}
          </div>
        </article>

        <section class="sec sig" data-file="signature.txt">
          <div class="sig__card">
            <div class="sig__text">
              <p class="sig__thanks">Keep experimenting!</p>
              <p class="sig__bio">
                Quick hacks and tips from my daily workflow. Found this useful? Let me know.
              </p>
            </div>
            <a
              href="https://x.com/samuellawrentz"
              target="_blank"
              rel="noreferrer"
              class="sig__cta"
            >
              @samuellawrentz →
            </a>
          </div>
        </section>

        {relatedHacks && relatedHacks.length > 0 && (
          <section class="sec" data-file="related.log">
            <header class="sec__head">
              <div>
                <p class="cmd"><span class="t-green">$</span> ls ../{hackCategory} | head -4</p>
                <h2 class="sec__title">More hacks</h2>
              </div>
              <a href={`/hacks/${hackCategory}/`} class="sec__link">cd ../{hackCategory} →</a>
            </header>
            <ol class="gitlog">
              {relatedHacks.map((h) => (
                <li class="commit">
                  <span class="commit__graph" aria-hidden="true"><i class="commit__node"></i></span>
                  <a href={ensureTrailingSlash(h.data.path)} class="commit__card">
                    <div class="commit__main">
                      <p class="commit__line1">
                        <code class="commit__hash">{hashOf(h.data.title)}</code>
                        <span class="commit__title">{h.data.title}</span>
                      </p>
                      <p class="commit__meta">
                        {h.data.tags.slice(0, 3).map((tag: string) => (
                          <span class="commit__tag">tag: {tag}</span>
                        ))}
                      </p>
                    </div>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        )}

      </div>
    </IdeWindow>
  )}
</BaseLayout>

<style lang="scss">
  .sec--cat {
    padding-top: 48px;
  }

  /* file rows: no count column, description under the title */
  .ls__row--file {
    grid-template-columns: 110px 60px minmax(0, 1fr) auto;
  }

  .ls__file-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .ls__file-body .ls__name {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 15px;
    line-height: 1.4;
    white-space: normal;
  }

  .ls__desc {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    color: var(--ide-dim);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .ls__row--file {
      grid-template-columns: 1fr auto;
    }
  }
</style>
